{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenPOS",
  "version": "0.2.5",
  "identifier": "com.openpos.app",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenPOS",
        "width": 1200,
        "minWidth": 1200,
        "height": 800,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxMUEzNTkyRTE0QTk5MTIKUldRU21VcmhralVha1NydHdtc2RrOE9WaHdyOXpMWXV4dHJxZExEd1JFanEvQU1wbkRmWWZvWXIK",
      "endpoints": [
        "https://github.com/dancaldera/OpenPOS/releases/latest/download/{{target}}-{{arch}}.json"
      ]
    }
  }
}
