# Turso Database Configuration
# Get these values from your Turso dashboard or CLI:
# - turso db show <database-name> (for URL)
# - turso auth create-token -e none (for auth token)

VITE_TURSO_DATABASE_URL=libsql://your-database.turso.io
VITE_TURSO_AUTH_TOKEN=your-auth-token-here

# If Turso credentials are not provided, the app will use local SQLite

# Web API Server Configuration (for Vercel deployment)
# These are used by the Hono API server for JWT signing and database access

TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
JWT_SECRET=your-very-secure-jwt-secret-key-here

# CORS Configuration for Web API
# Set this to your Vercel deployment URL (e.g., https://your-app.vercel.app)
# If not set, allows localhost origins for development
ALLOWED_ORIGIN=https://your-openpos-app.vercel.app
