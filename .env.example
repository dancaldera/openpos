# OpenPOS environment template
#
# Desktop local default:
# - No env vars required
# - Public desktop releases should use runtime config at:
#   ~/.config/com.openpos.app/config.json
#
# Use the variables below only when you need remote Turso access
# or when running the web/API deployment.

# ---------------------------------------------------------------------------
# Remote database (optional)
# Used by:
# - desktop local development or internal CI
# - Turso scripts
# - API server
# Not for:
# - public desktop release embedding
# ---------------------------------------------------------------------------
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ---------------------------------------------------------------------------
# API auth (required only for web/API deployments)
# Used by:
# - api/src/middleware/auth.ts
# Not needed for:
# - desktop-only local usage
# - public desktop release builds
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# API CORS (optional, web/API only)
# Set this in deployed API environments.
# If omitted, localhost origins are allowed in development.
# ---------------------------------------------------------------------------
ALLOWED_ORIGIN=https://your-openpos-app.vercel.app

# ---------------------------------------------------------------------------
# Frontend web API base URL (optional, web frontend only)
# Leave empty for same-origin /api usage.
# Example:
# VITE_API_URL=https://your-api.example.com
# ---------------------------------------------------------------------------
VITE_API_URL=
