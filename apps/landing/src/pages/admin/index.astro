---
export const prerender = false

import AdminLayout from '../../layouts/AdminLayout.astro'
import { listClients } from '../../lib/registry'
import { listDatabases, toLibsqlUrl } from '../../lib/turso-platform'

let error: string | null = null
let databases: Array<{
  name: string
  url: string
  group: string
  clientName: string | null
  clientId: string | null
}> = []

try {
  const [tursoDatabases, clients] = await Promise.all([listDatabases(), listClients()])
  const clientByDatabase = new Map(
    clients.filter((client) => client.database_name).map((client) => [client.database_name!, client]),
  )

  databases = tursoDatabases.map((database) => {
    const client = clientByDatabase.get(database.Name)
    return {
      name: database.Name,
      url: toLibsqlUrl(database.Hostname),
      group: database.group,
      clientName: client?.name ?? null,
      clientId: client?.id ?? null,
    }
  })
} catch (err) {
  error = err instanceof Error ? err.message : 'Failed to load dashboard'
}
---

<AdminLayout title="Dashboard" active="dashboard">
  {error ? (
    <div class="rounded-[var(--radius-cards)] border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-900 dark:bg-red-950/40 dark:text-red-300">
      {error}
    </div>
  ) : (
    <>
      <div class="mb-6 grid gap-4 sm:grid-cols-3">
        <div class="rounded-[var(--radius-cards)] border border-fog-border bg-canvas p-5 shadow-sm">
          <p class="text-caption text-graphite">Databases</p>
          <p class="mt-2 text-heading-lg font-semibold">{databases.length}</p>
        </div>
        <div class="rounded-[var(--radius-cards)] border border-fog-border bg-canvas p-5 shadow-sm">
          <p class="text-caption text-graphite">Linked clients</p>
          <p class="mt-2 text-heading-lg font-semibold">{databases.filter((db) => db.clientName).length}</p>
        </div>
        <div class="rounded-[var(--radius-cards)] border border-fog-border bg-canvas p-5 shadow-sm">
          <p class="text-caption text-graphite">Unlinked databases</p>
          <p class="mt-2 text-heading-lg font-semibold">{databases.filter((db) => !db.clientName).length}</p>
        </div>
      </div>

      <div class="overflow-hidden rounded-[var(--radius-cards)] border border-fog-border bg-canvas shadow-sm">
        <div class="border-b border-fog-border px-5 py-4">
          <h2 class="text-sm font-semibold">Organization databases</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full text-left text-sm">
            <thead class="border-b border-fog-border bg-chalk/40 text-graphite">
              <tr>
                <th class="px-5 py-3 font-medium">Name</th>
                <th class="px-5 py-3 font-medium">URL</th>
                <th class="px-5 py-3 font-medium">Group</th>
                <th class="px-5 py-3 font-medium">Client</th>
                <th class="px-5 py-3 font-medium">Actions</th>
              </tr>
            </thead>
            <tbody>
              {databases.map((database) => (
                <tr class="border-b border-fog-border last:border-b-0">
                  <td class="px-5 py-3 font-medium">{database.name}</td>
                  <td class="px-5 py-3">
                    <div class="flex items-center gap-2">
                      <code class="max-w-[240px] truncate text-xs">{database.url}</code>
                      <button
                        type="button"
                        class="copy-btn rounded-buttons border border-fog-border px-2 py-1 text-xs"
                        data-copy={database.url}
                      >
                        Copy
                      </button>
                    </div>
                  </td>
                  <td class="px-5 py-3">{database.group}</td>
                  <td class="px-5 py-3">
                    {database.clientName ? (
                      <a href={`/admin/clients/${database.clientId}`} class="underline underline-offset-4">
                        {database.clientName}
                      </a>
                    ) : (
                      <span class="text-graphite">—</span>
                    )}
                  </td>
                  <td class="px-5 py-3">
                    <div class="flex flex-wrap gap-2">
                      <button
                        type="button"
                        class="token-btn rounded-buttons border border-fog-border px-3 py-1 text-xs"
                        data-db={database.name}
                        data-client={database.clientId ?? ''}
                      >
                        Token
                      </button>
                      <button
                        type="button"
                        class="rotate-btn rounded-buttons border border-fog-border px-3 py-1 text-xs"
                        data-db={database.name}
                        data-client={database.clientId ?? ''}
                      >
                        Rotate
                      </button>
                      {database.clientId && (
                        <a
                          href={`/admin/console?client=${database.clientId}`}
                          class="inline-flex rounded-buttons bg-void px-3 py-1 text-xs text-canvas"
                        >
                          Console
                        </a>
                      )}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <p id="dashboard-status" class="mt-4 hidden text-sm text-graphite"></p>
    </>
  )}
</AdminLayout>

<script>
  async function copyText(value: string) {
    await navigator.clipboard.writeText(value)
  }

  document.querySelectorAll('.copy-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      const value = button.getAttribute('data-copy')
      if (!value) return
      await copyText(value)
      button.textContent = 'Copied'
      setTimeout(() => {
        button.textContent = 'Copy'
      }, 1200)
    })
  })

  const statusEl = document.getElementById('dashboard-status')

  function showStatus(message: string) {
    if (!statusEl) return
    statusEl.textContent = message
    statusEl.classList.remove('hidden')
  }

  document.querySelectorAll('.token-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      const db = button.getAttribute('data-db')
      const clientId = button.getAttribute('data-client')
      if (!db) return

      const response = await fetch(`/api/admin/databases/${encodeURIComponent(db)}/token`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ clientId: clientId || undefined }),
      })
      const payload = await response.json()
      if (!response.ok) {
        showStatus(payload.error ?? 'Failed to mint token')
        return
      }
      await copyText(payload.jwt)
      showStatus(`Token minted for ${db} and copied to clipboard.`)
    })
  })

  document.querySelectorAll('.rotate-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      const db = button.getAttribute('data-db')
      const clientId = button.getAttribute('data-client')
      if (!db) return
      if (!confirm(`Rotate all tokens for ${db}? Existing tokens will stop working.`)) return

      const response = await fetch(`/api/admin/databases/${encodeURIComponent(db)}/rotate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ clientId: clientId || undefined }),
      })
      const payload = await response.json()
      if (!response.ok) {
        showStatus(payload.error ?? 'Failed to rotate tokens')
        return
      }
      await copyText(payload.jwt)
      showStatus(`Tokens rotated for ${db}. New token copied to clipboard.`)
    })
  })
</script>
