---
import '../styles/global.css'

interface Props {
  title: string
  active?: 'dashboard' | 'clients' | 'console'
}

const { title, active = 'dashboard' } = Astro.props
const navItems = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin' },
  { id: 'clients', label: 'Clients', href: '/admin/clients' },
  { id: 'console', label: 'Console', href: '/admin/console' },
] as const
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · OpenPOS Admin</title>
  </head>
  <body class="min-h-screen bg-canvas font-sans text-void antialiased">
    <div class="flex min-h-screen">
      <aside class="hidden w-64 shrink-0 border-r border-fog-border bg-chalk/40 p-6 lg:block">
        <a href="/admin" class="mb-8 inline-flex items-center gap-2 text-[17px] font-semibold tracking-[-0.01em]">
          <span class="flex h-8 w-8 items-center justify-center rounded-buttons border border-fog-border text-caption font-semibold">
            OP
          </span>
          <span>Admin</span>
        </a>
        <nav class="flex flex-col gap-2">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-buttons px-4 py-2 text-sm font-medium transition-colors',
                active === item.id
                  ? 'bg-void text-canvas'
                  : 'text-void hover:bg-canvas',
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <form method="post" action="/api/admin/logout" class="mt-8" id="logout-form">
          <button
            type="submit"
            class="w-full rounded-buttons border border-fog-border px-4 py-2 text-sm font-medium transition-colors hover:bg-canvas"
          >
            Log out
          </button>
        </form>
      </aside>

      <div class="flex min-w-0 flex-1 flex-col">
        <header class="border-b border-fog-border px-4 py-4 sm:px-6 lg:px-8">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
              <p class="text-caption text-graphite">OpenPOS fleet</p>
              <h1 class="text-heading font-semibold tracking-[-0.02em]">{title}</h1>
            </div>
            <nav class="flex items-center gap-2 lg:hidden">
              {navItems.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'rounded-buttons px-3 py-1.5 text-sm font-medium',
                    active === item.id ? 'bg-void text-canvas' : 'border border-fog-border',
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </nav>
          </div>
        </header>

        <main class="flex-1 px-4 py-6 sm:px-6 lg:px-8">
          <slot />
        </main>
      </div>
    </div>

    <script>
      document.getElementById('logout-form')?.addEventListener('submit', async (event) => {
        event.preventDefault()
        await fetch('/api/admin/logout', { method: 'POST' })
        window.location.href = '/admin/login'
      })
    </script>
  </body>
</html>
