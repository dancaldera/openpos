---
const markers = ['Self-hosted', 'No subscriptions', 'Offline-first']
---

<section class="bg-canvas px-4 py-24 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-[720px] text-center">
    <p class="text-caption font-medium tracking-[0.011em] text-graphite">Built for retail</p>

    <h2 class="mt-4 text-heading-lg font-semibold leading-[1.21] tracking-[-0.01em] text-void sm:text-display sm:leading-[1.16] sm:tracking-[-1.44px]">
      Ready to modernize your point of sale?
    </h2>

    <p class="mt-5 text-base leading-[1.65] text-graphite sm:text-[18px]">
      A modern POS system designed for retailers who demand more. No subscriptions, no hidden fees.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href="https://demo.openpos.xyz"
        class="inline-flex w-full items-center justify-center gap-2 rounded-buttons bg-void px-6 py-3 text-sm font-medium text-canvas shadow-sm transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void sm:w-auto"
      >
        Try Demo
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m0 0-5-5m5 5-5 5" />
        </svg>
      </a>

      <a
        href="https://github.com/dancaldera/openpos"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex w-full items-center justify-center gap-2 rounded-buttons border border-fog-border px-6 py-3 text-sm font-medium text-void transition-colors hover:bg-chalk focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void sm:w-auto"
      >
        View GitHub
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 17L17 7m0 0H9m8 0v8" />
        </svg>
      </a>
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm text-graphite">
      {markers.map((marker, index) => (
        <>
          <span>{marker}</span>
          {index < markers.length - 1 && <span aria-hidden="true">·</span>}
        </>
      ))}
    </div>
  </div>
</section>
