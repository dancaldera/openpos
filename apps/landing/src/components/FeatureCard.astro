---
interface Props {
  icon: string
  title: string
  description: string
}

const { icon, title, description } = Astro.props

const icons: Record<string, string> = {
  offline: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M18.364 5.636a9 9 0 010 12.728m0 0L15.535 15.535m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072M8.464 15.536a5 5 0 01-1.414-2.83M5.636 18.364a9 9 0 01-2.167-9.238M12.707 12.707a1 1 0 01-1.414-1.414M3 3l18 18" /></svg>`,
  sync: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 4v5h5M20 20v-5h-5M5.64 15.5a7 7 0 0011.71 2.85M18.36 8.5A7 7 0 006.65 5.65" /></svg>`,
  desktop: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 5h16v11H4zM9 20h6M12 16v4" /></svg>`,
  language: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 5h10M9 3v2m1.2 9a15.5 15.5 0 01-4.8-5M6 14a15.4 15.4 0 005-8M14 21l4-9 4 9m-6.6-3h5.2" /></svg>`,
  users: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 11a4 4 0 10-8 0m8 0a4 4 0 11-8 0m8 0v1a4 4 0 01-8 0v-1M4 21a8 8 0 0116 0" /></svg>`,
  variants: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 7h14M5 12h14M5 17h14M8 5v4m8 1v4m-5 1v4" /></svg>`,
  barcode: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7V5h2M18 5h2v2M20 17v2h-2M6 19H4v-2M7 8v8m3-8v8m3-8v8m4-8v8" /></svg>`,
  analytics: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 19V9m7 10V5m7 14v-7M4 19h16" /></svg>`,
  loyalty: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 21s-7-4.35-7-10a4 4 0 017-2.65A4 4 0 0119 11c0 5.65-7 10-7 10z" /></svg>`,
  print: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 8V4h10v4M7 17H5a2 2 0 01-2-2v-4h18v4a2 2 0 01-2 2h-2M7 14h10v6H7z" /></svg>`,
}
---

<article class="group rounded-cards border border-fog-border bg-canvas p-6 transition-colors hover:bg-chalk">
  <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-softbutton bg-chalk text-void">
    <Fragment set:html={icons[icon] || icons.offline} />
  </div>
  <h3 class="text-[18px] font-semibold leading-tight text-void">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-graphite">{description}</p>
</article>
