---
const year = new Date().getFullYear()

const quickLinks = [
  { label: 'Features', href: '#features' },
  { label: 'AI Roadmap', href: '#ai-roadmap' },
  { label: 'Live Demo', href: 'https://demo.openpos.xyz' },
]

const contactLinks = [
  { label: 'GitHub', href: 'https://github.com/dancaldera/openpos', external: true },
  { label: 'dancaldera@proton.me', href: 'mailto:dancaldera@proton.me' },
]
---

<footer class="border-t border-fog-border bg-canvas">
  <div class="mx-auto max-w-[1200px] px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-4 lg:gap-16">
      <div class="md:col-span-2">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-links text-[17px] font-semibold tracking-[-0.01em] text-void focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void"
        >
          <span class="flex h-8 w-8 items-center justify-center rounded-buttons border border-fog-border text-caption font-semibold">
            OP
          </span>
          <span>OpenPOS</span>
        </a>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-graphite">
          A modern Point of Sale system with AI-powered features on the horizon.
          Built for retailers who demand more from their software.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a
            href="https://github.com/dancaldera/openpos"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="OpenPOS on GitHub"
            class="inline-flex h-10 w-10 items-center justify-center rounded-buttons border border-fog-border text-graphite transition-colors hover:bg-chalk hover:text-void focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
          <a
            href="mailto:dancaldera@proton.me"
            aria-label="Email OpenPOS"
            class="inline-flex h-10 w-10 items-center justify-center rounded-buttons border border-fog-border text-graphite transition-colors hover:bg-chalk hover:text-void focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 6h16v12H4zM4 7l8 6 8-6" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-caption font-semibold tracking-[0.011em] text-void">Quick Links</h3>
        <ul class="mt-4 space-y-2">
          {quickLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="rounded-links text-caption font-normal text-graphite underline-offset-4 hover:text-void hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-caption font-semibold tracking-[0.011em] text-void">Contact</h3>
        <ul class="mt-4 space-y-2">
          {contactLinks.map(link => (
            <li>
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                class="rounded-links text-caption font-normal text-graphite underline-offset-4 hover:text-void hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-3 border-t border-fog-border pt-8 text-sm text-ash md:flex-row md:items-center md:justify-between">
      <p>&copy; {year} OpenPOS. All rights reserved.</p>
      <p>All systems operational</p>
    </div>
  </div>
</footer>
