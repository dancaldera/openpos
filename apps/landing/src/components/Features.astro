---
import FeatureCard from './FeatureCard.astro'

const features = [
  {
    icon: 'offline',
    title: 'Offline-First',
    description: 'Works without internet connection. All your data stays local and syncs automatically when you are back online.',
  },
  {
    icon: 'sync',
    title: 'Real-Time Sync',
    description: 'Automatic cloud synchronization powered by Turso. Your data stays up to date across every device.',
  },
  {
    icon: 'desktop',
    title: 'Cross-Platform Desktop',
    description: 'Native apps for Linux, macOS, and Windows. One codebase, all platforms, consistent experience.',
  },
  {
    icon: 'language',
    title: 'Multi-Language',
    description: 'Full support for English and Spanish, with an architecture that can grow into more languages.',
  },
  {
    icon: 'users',
    title: 'Role-Based Access',
    description: 'Admin, Manager, and User roles keep team operations structured and permission-aware.',
  },
  {
    icon: 'variants',
    title: 'Product Variants',
    description: 'Advanced variant management with attributes, pricing, and stock levels for complex catalogs.',
  },
  {
    icon: 'barcode',
    title: 'Barcode Scanning',
    description: 'Quick product lookup with barcode scanner support for fast, high-volume checkout.',
  },
  {
    icon: 'analytics',
    title: 'Analytics Dashboard',
    description: 'Track sales, top products, and team performance with clear operational reporting.',
  },
  {
    icon: 'loyalty',
    title: 'Customer Loyalty',
    description: 'Built-in points and purchase tracking help reward your best customers automatically.',
  },
  {
    icon: 'print',
    title: 'Receipt Printing',
    description: 'Thermal printer support with customizable receipts for professional checkout output.',
  },
]
---

<section id="features" class="bg-canvas px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-[1200px]">
    <div class="mx-auto mb-16 max-w-3xl text-center md:mx-0 md:text-left">
      <p class="text-caption font-medium tracking-[0.011em] text-graphite">Features</p>
      <h2 class="mt-4 text-heading-lg font-semibold leading-[1.21] tracking-[-0.01em] text-void sm:text-display sm:leading-[1.16] sm:tracking-[-1.44px]">
        Everything you need to sell
      </h2>
      <p class="mt-5 text-base leading-[1.65] text-graphite sm:text-[18px]">
        A complete POS solution with the features modern retailers need. No subscriptions, no hidden fees.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {features.map(feature => (
        <FeatureCard {...feature} />
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="mb-5 text-sm text-graphite">And many more features in development</p>
      <a
        href="https://demo.openpos.xyz"
        class="inline-flex items-center gap-2 rounded-buttons bg-void px-5 py-3 text-sm font-medium text-canvas shadow-sm transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void"
      >
        Explore all features
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12h14m0 0-5-5m5 5-5 5" />
        </svg>
      </a>
    </div>
  </div>
</section>
