---
const roadmapItems = [
  {
    title: 'Smart inventory predictions',
    description: 'AI analyzes sales patterns to predict stock needs and flag items that may need attention.',
    label: 'Predictive analytics',
  },
  {
    title: 'Voice commands',
    description: 'Natural language workflows for common tasks like checking sales, adding items, and finding products.',
    label: 'Natural language processing',
  },
  {
    title: 'Automated insights',
    description: 'Daily business recommendations that surface trends, risks, and opportunities without dashboard hunting.',
    label: 'Machine learning',
  },
  {
    title: 'Smart customer insights',
    description: 'Customer segmentation, loyalty signals, and behavior patterns designed for practical retail decisions.',
    label: 'Customer intelligence',
  },
]
---

<section id="ai-roadmap" class="bg-canvas px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-[1200px]">
    <div class="mx-auto mb-16 max-w-3xl text-center">
      <p class="text-caption font-medium tracking-[0.011em] text-graphite">Coming soon</p>
      <h2 class="mt-4 text-heading-lg font-semibold leading-[1.21] tracking-[-0.01em] text-void sm:text-display sm:leading-[1.16] sm:tracking-[-1.44px]">
        AI roadmap
      </h2>
      <p class="mt-5 text-base leading-[1.65] text-graphite sm:text-[18px]">
        AI features are planned around inventory, voice workflows, business insights, and customer intelligence.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {roadmapItems.map(item => (
        <article class="rounded-cards border border-fog-border bg-canvas p-8 transition-colors hover:bg-chalk">
          <p class="text-caption font-medium tracking-[0.011em] text-graphite">{item.label}</p>
          <h3 class="mt-4 text-heading font-semibold leading-[1.26] text-void">{item.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-graphite sm:text-base">{item.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="mb-5 text-sm text-graphite">Be the first to know when AI features launch</p>
      <a
        href="https://github.com/dancaldera/openpos"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-buttons border border-fog-border px-5 py-3 text-sm font-medium text-void transition-colors hover:bg-chalk focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-void"
      >
        Watch the repository
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 17L17 7m0 0H9m8 0v8" />
        </svg>
      </a>
    </div>
  </div>
</section>
