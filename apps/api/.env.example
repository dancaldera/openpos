# OpenPOS API environment template
#
# Required for the API to connect to the remote Turso database.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Required for JWT auth on protected API routes.
JWT_SECRET=replace-with-a-long-random-secret

# Optional for deployed browser clients.
# If omitted, localhost dev origins remain allowed.
ALLOWED_ORIGIN=https://your-openpos-app.vercel.app

# Optional for standalone local/server deployments.
PORT=3001
