# OpenPOS Desktop environment template
#
# Local desktop usage works without env vars by default.
# Use the variables below only when needed.

# Optional remote Turso connection for desktop development and DB scripts.
# Note: current `scripts/migrate-turso.ts` and `scripts/create-admin.ts`
# read these values from the repo root `.env.local`.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Optional for the browser/web build of the desktop renderer.
# Leave empty for same-origin `/api` requests.
VITE_API_URL=

# Optional printer override for Electron desktop runtime.
# Defaults to `lp`.
OPENPOS_PRINTER_COMMAND=lp
