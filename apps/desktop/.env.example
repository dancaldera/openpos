# OpenPOS Desktop environment template
#
# Public production Electron installs do not require env vars by default.
# Use ~/.config/com.openpos.app/config.json for production runtime settings.
# Keep secrets out of public desktop release artifacts.

# Optional printer override for Electron desktop runtime.
# Defaults to `lp`.
OPENPOS_PRINTER_COMMAND=lp

# Development or internal CI only: remote Turso overrides for local desktop
# runs and operational scripts. Do not use these as public release build inputs.
# Note: current DB scripts read these values from the repo root `.env.local`.
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Web/browser build only. Not required for packaged desktop production.
# Leave empty for same-origin `/api` requests in local web development.
# VITE_API_URL=https://your-api.example.com
