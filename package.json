{
  "name": "openpos",
  "version": "0.8.3",
  "private": true,
  "license": "MIT",
  "repository": "github:dancaldera/openpos",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev-runner.ts dev",
    "dev:desktop": "bun scripts/dev-runner.ts dev:desktop",
    "dev:desktop:web": "bun scripts/dev-runner.ts dev:desktop:web",
    "dev:api": "bun scripts/dev-runner.ts dev:api",
    "dev:landing": "bun scripts/dev-runner.ts dev:landing",
    "build": "bun run build:desktop",
    "build:desktop": "bun run --cwd apps/desktop build:desktop",
    "build:desktop:mac": "bun run --cwd apps/desktop build:desktop:mac",
    "build:desktop:linux": "bun run --cwd apps/desktop build:desktop:linux",
    "build:desktop:linux:appimage": "bun run --cwd apps/desktop build:desktop:linux:appimage",
    "build:desktop:linux:deb": "bun run --cwd apps/desktop build:desktop:linux:deb",
    "build:desktop:web": "bun run --cwd apps/desktop build:web",
    "build:api": "bun run --cwd apps/api build",
    "build:landing": "bun run --cwd apps/landing build",
    "db:migrate:remote": "bun run --cwd packages/data migrate:remote",
    "db:create-admin": "bun scripts/create-admin.ts",
    "db:build-bootstrap": "bun run --cwd packages/data build:bootstrap",
    "install:appimage": "bash scripts/install-latest-appimage.sh",
    "config:desktop": "bash scripts/create-desktop-config.sh",
    "version:bump": "bun scripts/bump-version.ts",
    "check": "tsc -p scripts/tsconfig.json && bun run --cwd apps/desktop check && bun run --cwd apps/api check",
    "test": "bun run test:scripts && bun run test:data && bun run test:sync && bun run test:desktop && bun run test:api",
    "test:scripts": "bun test scripts",
    "test:data": "bun test packages/data",
    "test:sync": "bun run --cwd packages/sync test",
    "test:desktop": "bun run --cwd apps/desktop test",
    "test:api": "bun run --cwd apps/api test"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
