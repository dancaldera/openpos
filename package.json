{
  "name": "openpos",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run dev:desktop",
    "dev:desktop": "bun run --cwd apps/desktop dev:desktop",
    "dev:desktop:web": "bun run --cwd apps/desktop dev:web",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:landing": "bun run --cwd apps/landing dev",
    "build": "bun run build:desktop",
    "build:desktop": "bun run --cwd apps/desktop build:desktop",
    "build:desktop:web": "bun run --cwd apps/desktop build:web",
    "build:api": "bun run --cwd apps/api build",
    "build:landing": "bun run --cwd apps/landing build",
    "check": "bun run --cwd apps/desktop check && bun run --cwd apps/api check"
  }
}
